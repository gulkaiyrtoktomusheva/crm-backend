POSTGRES_DB=ort_crm
POSTGRES_USER=ortcrm
POSTGRES_PASSWORD=change_me_strong_password

SERVER_PORT=8080
BACKEND_HOST_PORT=8087
SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/ort_crm
SPRING_DATASOURCE_USERNAME=ortcrm
SPRING_DATASOURCE_PASSWORD=change_me_strong_password

# Base64-encoded secret, at least 32 bytes before encoding.
JWT_SECRET=replace_with_openssl_rand_base64_64
JWT_EXPIRATION=86400000

# Comma-separated list of frontend origins allowed by CORS.
APP_CORS_ALLOWED_ORIGINS=http://localhost:8086

# Public hostname used by nginx.
APP_DOMAIN=example.com
